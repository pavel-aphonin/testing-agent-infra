# ============================================================
# Testing Agent — environment template
# Copy to .env and fill in. Never commit .env itself.
# ============================================================

# --- Postgres ---
POSTGRES_USER=testing_agent
POSTGRES_PASSWORD=change_me_long_random_string
POSTGRES_DB=testing_agent
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_32_byte_hex_string
JWT_ACCESS_TOKEN_EXPIRES_MIN=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# --- Initial admin (created by seed script on first run) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me_strong_password

# --- Worker (explorer daemon running on the host) ---
# Workers send this as a Bearer token to /api/internal/* endpoints.
# Generate with: openssl rand -hex 32
WORKER_TOKEN=change_me_worker_token_long_random_string

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000

# --- LLM (host-side llama-server processes, macOS) ---
# Gemma 4 E4B — exploration agent's chat LLM
LLM_PORT=8080
LLM_BASE_URL=http://host.docker.internal:8080
# Qwen3-Embedding-8B — RAG embeddings (4096 dim, 32K context)
EMBEDDING_BASE_URL=http://host.docker.internal:8082
# Qwen3-8B Instruct — RAG answer generation (better than Gemma for Russian Q&A)
RAG_LLM_BASE_URL=http://host.docker.internal:8083
# Qwen3-Reranker-8B — second-stage retrieval (over-fetch + rerank for precision)
RERANKER_BASE_URL=http://host.docker.internal:8084
# Shared models directory (bind-mounted into backend + llm containers)
LLM_MODELS_DIR=./volumes/llm-models

# --- Explorer ---
# iOS simulator tools (AXe, xcrun, appium) run on the HOST, not in the container.
# This is the host URL the explorer container uses to reach them.
EXPLORER_HOST_DEVICE_BRIDGE=http://host.docker.internal:9999

# --- Logging (PER-118) ---
# Three modes for centralised log collection:
#
#   none           Backend + worker write plain-text logs to container
#                  stdout. No ELK stack is run. Default — preserves the
#                  pre-PER-118 dev experience.
#   elasticsearch  Run our own ELK in docker (Elasticsearch + Kibana +
#                  Filebeat) under the ``logging`` profile. Backend +
#                  worker emit JSON; Filebeat tails the docker log files
#                  and ships them to Elasticsearch. Kibana on :5601.
#   external       Backend + worker emit JSON to stdout; the customer's
#                  own log collector (their ELK, Splunk, Datadog, etc.)
#                  picks them up. The fields are the same as in
#                  ``elasticsearch`` mode; only the destination is the
#                  customer's responsibility. Do NOT enable our profile
#                  ``logging`` in this mode.
#
# Switch with:
#   none            docker compose up -d
#   elasticsearch   docker compose --profile logging up -d
#   external        docker compose up -d  (+ point your collector at the
#                                            containers' stdout streams)
LOGGING_BACKEND=none

# Ports for our own ELK (only used when LOGGING_BACKEND=elasticsearch).
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# When LOGGING_BACKEND=external, point the backend (and other future
# producers) at the customer's Elasticsearch / OpenSearch endpoint.
# Empty string is fine for the other two modes.
ELASTICSEARCH_URL=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
